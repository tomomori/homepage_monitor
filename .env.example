# ============================================================
# ホームページ死活監視ツール 設定サンプル
#
# 使い方:
# 1. このファイルを .env という名前でコピーします
# 2. SMTP情報や認証情報を実際の値に変更します
# 3. .env は .gitignore によりGit管理対象外にします
# ============================================================

# ------------------------------------------------------------
# 監視対象URL一覧ファイル
# ------------------------------------------------------------
URLS_FILE=urls.tsv

# ------------------------------------------------------------
# ログ出力ディレクトリ
# ------------------------------------------------------------
LOG_DIR=logs

# ------------------------------------------------------------
# HTTPアクセスのタイムアウト秒数
# Playwright方式でも、この秒数を画面操作の待ち時間に使います。
# ------------------------------------------------------------
TIMEOUT=15

# ------------------------------------------------------------
# 異常時のリトライ回数
# 例: 2 の場合、初回 + 再試行2回 = 最大3回アクセスします
# ------------------------------------------------------------
RETRY_COUNT=1

# ------------------------------------------------------------
# リトライ前に待つ秒数
# ------------------------------------------------------------
RETRY_WAIT_SECONDS=3

# ------------------------------------------------------------
# 並列実行数
# 監視対象が多い場合は 5〜10 程度から始めるのがおすすめです。
# Playwright方式が多い場合は、まず 2〜3 程度から始めてください。
# ------------------------------------------------------------
MAX_WORKERS=5

# ------------------------------------------------------------
# Playwright方式でブラウザ画面を表示するか
# yes: 画面を表示しない通常実行
# no : ブラウザ画面を表示して動作確認しやすくする
# ------------------------------------------------------------
PLAYWRIGHT_HEADLESS=yes

# ------------------------------------------------------------
# SMTPサーバー設定
# STARTTLSの場合、ポートは一般的に 587 です
# ------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=password
SMTP_USE_TLS=yes

# ------------------------------------------------------------
# 送信元メールアドレス
# 未設定の場合は SMTP_USER を利用します
# ------------------------------------------------------------
MAIL_FROM=monitor@example.com

# ------------------------------------------------------------
# 全結果サマリーメール
# SUMMARY_MAIL_ENABLED=yes の場合、正常・異常をまとめたメールを最後に送信します。
# 宛先はカンマ区切りで複数指定できます。
# ------------------------------------------------------------
SUMMARY_MAIL_ENABLED=no
SUMMARY_MAIL_TO=admin@example.com

# ============================================================
# 認証ID方式の認証情報
#
# urls.tsv の「ログイン認証ID」に DJANGO_ADMIN と書いた場合、
# 以下の DJANGO_ADMIN_USER / DJANGO_ADMIN_PASSWORD が使われます。
#
# パスワードを urls.tsv に直接書かず、.env 側に分離するための方式です。
# ============================================================

# Basic認証サンプル
BASIC_SAMPLE_USER=user
BASIC_SAMPLE_PASSWORD=password

# アプリログインサンプル
APP_USER=admin
APP_PASSWORD=admin_password
